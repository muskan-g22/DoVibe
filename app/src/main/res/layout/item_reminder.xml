<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/task_card_bg"
    android:layout_marginBottom="10dp"
    android:padding="14dp"
    android:elevation="2dp">

    <!-- Row 1 : Type badge · Title · Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvReminderType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/badge_work"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/tvReminderTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:maxLines="1"
            android:ellipsize="end"/>

        <Switch
            android:id="@+id/switchReminderEnabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="@color/purple_primary"
            android:trackTint="#C5C3FF"/>

    </LinearLayout>

    <!-- Row 2 : Date · Repeat · Delete -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/tvReminderDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"/>

        <TextView
            android:id="@+id/tvReminderRepeat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/purple_primary"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/btnDeleteReminder"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#E24B4A"
            android:contentDescription="Delete reminder"/>

    </LinearLayout>

</LinearLayout>