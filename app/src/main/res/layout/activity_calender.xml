<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/header_bg"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="16dp" android:paddingBottom="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Dovibe" android:textColor="#CCFFFFFF" android:textSize="12sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Calendar" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Calendar widget — white bg + forced dark text so it's always readable -->
    <CalendarView
        android:id="@+id/calendarView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:dateTextAppearance="@style/CalendarDateText"
        android:weekDayTextAppearance="@style/CalendarWeekText"/>

    <!-- Selected date label -->
    <TextView
        android:id="@+id/tvSelectedDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="10dp" android:paddingBottom="6dp"
        android:textSize="14sp" android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:text="Today"/>

    <!-- Empty label -->
    <TextView
        android:id="@+id/tvNoTasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No tasks for this day 🎉"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp"
        android:gravity="center" android:paddingTop="20dp"
        android:visibility="gone"/>

    <!-- Task list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCalendarTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:paddingBottom="8dp" android:clipToPadding="false"/>

    <!-- Bottom nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>